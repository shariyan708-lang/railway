# Telegram bot token from @BotFather.
BOT_TOKEN=1234567890:replace_with_your_bot_token

# Telegram numeric user IDs that can open /admin.
# Only these accounts will see and use the Telegram admin panel.
ADMIN_IDS=111111111,222222222

# Bot username without @. Used to generate referral links.
BOT_USERNAME=your_bot_username

# Neon PostgreSQL connection string.
# Use the pooled Neon URL when hosting on Railway or Render.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Local SQLite fallback. Used only when DATABASE_URL is empty.
DB_PATH=data/telegram_selling_bot.sqlite3

# Performance tuning.
# Successful channel join checks are cached for this many seconds.
JOIN_CACHE_SECONDS=300

# Settings are cached briefly to reduce database reads.
SETTINGS_CACHE_SECONDS=5

# PostgreSQL/Neon connection stability.
# These keep Railway/Neon SSL connections alive and reconnect quickly if idle connections close.
PG_CONNECT_TIMEOUT=10
PG_KEEPALIVES_IDLE=30
PG_KEEPALIVES_INTERVAL=10
PG_KEEPALIVES_COUNT=5
PG_RECONNECT_LOG_SECONDS=60

# Telegram broadcast throttle. 0.035 is fast but still gentle for Telegram limits.
BROADCAST_DELAY_SECONDS=0.035
